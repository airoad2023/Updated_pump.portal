        "v_tokens_in_bonding_curve": to_float(data.get("vTokensInBondingCurve")),
        "v_sol_in_bonding_curve": to_float(data.get("vSolInBondingCurve")),
        "is_mayhem_mode": is_mayhem_mode,
        "pool": data.get("pool"),
        "duplicate_name_count": duplicate_name_count,
        "duplicate_symbol_count": duplicate_symbol_count,
        "creator_previous_launches": creator_previous_launches,
        "creator_previous_migrations": creator_previous_migrations,
        "raw_json": json.dumps(data, ensure_ascii=False),
    }


def save_migration(data: dict, raw_event_id: int, received_at: datetime):
    mint = data.get("mint")
    if not mint:
        return

    cursor.execute("SELECT launch_time, creator_wallet FROM launches WHERE mint = %s LIMIT 1", (mint,))
    launch_row = cursor.fetchone()
    if not launch_row:
        return

    launch_time = launch_row["launch_time"]
    creator_wallet = launch_row["creator_wallet"]

    minutes_from_launch = None
    if launch_time:
        minutes_from_launch = int((received_at - launch_time).total_seconds() // 60)

    cursor.execute("""
    INSERT IGNORE INTO migrations (mint, migration_time, received_at, raw_event_id, minutes_from_launch, migration_status)
    VALUES (%s, %s, %s, %s, %s, 'confirmed')
    """, (mint, received_at, received_at, raw_event_id, minutes_from_launch))
    mydb.commit()

    if cursor.rowcount == 1:
        cursor.execute("""
        UPDATE launches
        SET is_migrated = TRUE, migration_time = %s, minutes_to_migration = %s
        WHERE mint = %s
        """, (received_at, minutes_from_launch, mint))
        mydb.commit()

        if creator_wallet:
            increase_creator_migration_count(creator_wallet, received_at)

        cursor.execute("""
        UPDATE pump_5_10_trade_research_results
        SET final_status = COALESCE(final_status, 'migrated')
        WHERE mint = %s
        """, (mint,))
        mydb.commit()

        print("Migration saved:", mint, "| minutes:", minutes_from_launch)


