    initial_buy = to_float(data.get("initialBuy"))
    market_cap_sol = to_float(data.get("marketCapSol"))
    is_mayhem_mode = to_bool(
        data.get("is_mayhem_mode") if data.get("is_mayhem_mode") is not None else data.get("isMayhemMode")
    )

    cursor.execute("""
    INSERT IGNORE INTO launches (
        mint, name, symbol, creator_wallet, launch_time, received_at, raw_event_id,
        name_lower, symbol_lower, launch_date, launch_hour, launch_day_of_week,
        duplicate_name_count_at_launch, duplicate_symbol_count_at_launch,
