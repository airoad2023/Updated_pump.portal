    mydb.commit()
    return int(cursor.lastrowid)


def get_creator_previous_stats(creator_wallet: Optional[str]):
    if not creator_wallet:
        return 0, 0

    cursor.execute("""
    SELECT total_launches, total_migrations
    FROM creators
    WHERE creator_wallet = %s
    LIMIT 1
    """, (creator_wallet,))
    row = cursor.fetchone()

    if not row:
        return 0, 0

    return int(row["total_launches"] or 0), int(row["total_migrations"] or 0)


def ensure_creator_exists(creator_wallet: str, seen_at: datetime):
    cursor.execute("""
    INSERT INTO creators (creator_wallet, first_seen_at, last_seen_at, total_launches, total_migrations)
    VALUES (%s, %s, %s, 0, 0)
    ON DUPLICATE KEY UPDATE last_seen_at = VALUES(last_seen_at)
    """, (creator_wallet, seen_at, seen_at))
    mydb.commit()


def increase_creator_launch_count(creator_wallet: str, seen_at: datetime):
    cursor.execute("""
    UPDATE creators
    SET total_launches = total_launches + 1, last_seen_at = %s
    WHERE creator_wallet = %s
    """, (seen_at, creator_wallet))
    mydb.commit()


def increase_creator_migration_count(creator_wallet: str, seen_at: datetime):
    cursor.execute("""
    UPDATE creators
    SET total_migrations = total_migrations + 1, last_seen_at = %s
    WHERE creator_wallet = %s
    """, (seen_at, creator_wallet))
    mydb.commit()


def get_duplicate_counts(name_lower: Optional[str], symbol_lower: Optional[str]):
    duplicate_name_count = 0
    duplicate_symbol_count = 0

    if name_lower:
        cursor.execute("SELECT COUNT(*) AS total FROM launches WHERE name_lower = %s", (name_lower,))
        duplicate_name_count = int(cursor.fetchone()["total"] or 0)

    if symbol_lower:
        cursor.execute("SELECT COUNT(*) AS total FROM launches WHERE symbol_lower = %s", (symbol_lower,))
        duplicate_symbol_count = int(cursor.fetchone()["total"] or 0)

    return duplicate_name_count, duplicate_symbol_count


