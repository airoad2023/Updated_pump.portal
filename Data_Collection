    VALUES (%s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s)
    """, (
        mint, name, symbol, creator_wallet, received_at, received_at, raw_event_id,
        name_lower, symbol_lower, launch_date, launch_hour, launch_day_of_week,
        duplicate_name_count, duplicate_symbol_count,
        sol_amount, initial_buy, market_cap_sol, data.get("bondingCurveKey"),
        to_float(data.get("vTokensInBondingCurve")),
        to_float(data.get("vSolInBondingCurve")),
        is_mayhem_mode, data.get("pool"), data.get("uri")
