def save_token_trade(
    data: dict,
    tracked_token_id_by_mint: Dict[str, int],
    launch_time_ts_by_mint: Dict[str, float],
    trade_sequence_by_mint: Dict[str, int],
):
    mint = data.get("mint")
    signature = data.get("signature")
    tx_type = data.get("txType")

    raw_event_id = save_paid_raw_event(tx_type, mint, signature, data)

    token_amount = data.get("tokenAmount") or data.get("initialBuy")
    sol_amount = data.get("solAmount")
    price_sol = calculate_price_sol(sol_amount, token_amount)

    launch_ts = launch_time_ts_by_mint.get(mint)
    seconds_after_launch = round(time.time() - launch_ts, 3) if launch_ts else None

    trade_sequence_by_mint[mint] = trade_sequence_by_mint.get(mint, 0) + 1

    cursor.execute("""
    INSERT IGNORE INTO pump_token_trades (
        collection_run_id, tracked_token_id, signature, mint, trader_public_key, tx_type,
        token_amount, sol_amount, price_sol, bonding_curve_key, v_tokens_in_bonding_curve,
        v_sol_in_bonding_curve, market_cap_sol, trade_sequence, seconds_after_launch,
        pool, raw_event_id, raw_json
    )
    VALUES (%s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s)
    """, (
        COLLECTION_RUN_ID, tracked_token_id_by_mint.get(mint), signature, mint,
        data.get("traderPublicKey"), tx_type, to_float(token_amount), to_float(sol_amount),
        price_sol, data.get("bondingCurveKey"), to_float(data.get("vTokensInBondingCurve")),
        to_float(data.get("vSolInBondingCurve")), to_float(data.get("marketCapSol")),
        trade_sequence_by_mint[mint], seconds_after_launch, data.get("pool"), raw_event_id,
        json.dumps(data, ensure_ascii=False)
    ))
    mydb.commit()


