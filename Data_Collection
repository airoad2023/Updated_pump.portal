def now_datetime() -> datetime:
    return datetime.now()


def clean_text(value: Any) -> Optional[str]:
    if value is None:
        return None
    value = str(value).strip()
    return value if value else None


def lower_text(value: Any) -> Optional[str]:
    value = clean_text(value)
    return value.lower() if value else None


def to_float(value: Any) -> Optional[float]:
    if value is None:
        return None
    try:
        return float(value)
    except Exception:
        return None


def to_bool(value: Any) -> Optional[bool]:
    if value is None:
        return None
    if isinstance(value, bool):
        return value
    if isinstance(value, int):
        return bool(value)
    if isinstance(value, str):
        return value.lower() in ["true", "1", "yes"]
    return None


def market_cap_usd_from_sol(market_cap_sol: Optional[float]) -> Optional[float]:
    if market_cap_sol is None:
        return None
    return float(market_cap_sol) * float(SOL_USD_PRICE_MANUAL)


def calculate_price_sol(sol_amount: Any, token_amount: Any) -> Optional[float]:
    sol = to_float(sol_amount)
    tokens = to_float(token_amount)
    if sol is None or tokens is None or tokens == 0:
        return None
    return sol / tokens


def calculate_ratio(numerator: Any, denominator: Any) -> Optional[float]:
    n = float(numerator or 0)
    d = float(denominator or 0)
    if d == 0:
        return n if n > 0 else None
    return n / d


def get_launch_time_parts(received_at: datetime):
    return received_at.date(), received_at.hour, received_at.weekday() + 1


def threshold_flags(mc_usd: float) -> Dict[str, bool]:
    return {
        "passed_5k": mc_usd >= THRESHOLD_5K,
        "passed_7500": mc_usd >= THRESHOLD_7500,
        "passed_10k": mc_usd >= THRESHOLD_10K,
    }


def threshold_label(mc_usd: float) -> str:
    if mc_usd >= THRESHOLD_10K:
        return "10k_plus"
    if mc_usd >= THRESHOLD_7500:
        return "7500_plus"
    if mc_usd >= THRESHOLD_5K:
        return "5k_plus"
    return "below_5k"


