def save_snapshot(mint: str, tracked_token_id: int, seconds_after_launch: int) -> Optional[Dict[str, Any]]:
    cursor.execute("SELECT * FROM pump_tracked_tokens WHERE id = %s LIMIT 1", (tracked_token_id,))
    tracked = cursor.fetchone()
    if not tracked:
        return None

    creator_wallet = tracked.get("creator_wallet")
    start_market_cap = tracked.get("market_cap_sol")

    cursor.execute("""
    SELECT
        COUNT(*) AS total_trades,
        SUM(CASE WHEN tx_type = 'buy' THEN 1 ELSE 0 END) AS buy_count,
        SUM(CASE WHEN tx_type = 'sell' THEN 1 ELSE 0 END) AS sell_count,
        COUNT(DISTINCT trader_public_key) AS unique_traders,
        COUNT(DISTINCT CASE WHEN tx_type = 'buy' THEN trader_public_key END) AS unique_buyers,
        COUNT(DISTINCT CASE WHEN tx_type = 'sell' THEN trader_public_key END) AS unique_sellers,
        COALESCE(SUM(sol_amount), 0) AS total_volume_sol,
        COALESCE(SUM(CASE WHEN tx_type = 'buy' THEN sol_amount ELSE 0 END), 0) AS buy_volume_sol,
        COALESCE(SUM(CASE WHEN tx_type = 'sell' THEN sol_amount ELSE 0 END), 0) AS sell_volume_sol,
        AVG(CASE WHEN tx_type = 'buy' THEN sol_amount END) AS average_buy_sol,
        AVG(CASE WHEN tx_type = 'sell' THEN sol_amount END) AS average_sell_sol,
        MAX(CASE WHEN tx_type = 'buy' THEN sol_amount END) AS largest_buy_sol,
        MAX(CASE WHEN tx_type = 'sell' THEN sol_amount END) AS largest_sell_sol,
        MAX(market_cap_sol) AS highest_market_cap_sol,
        MIN(market_cap_sol) AS lowest_market_cap_sol,
        MIN(seconds_after_launch) AS first_trade_seconds,
        MIN(CASE WHEN tx_type = 'buy' THEN seconds_after_launch END) AS first_buy_seconds,
        MIN(CASE WHEN tx_type = 'sell' THEN seconds_after_launch END) AS first_sell_seconds
    FROM pump_token_trades
    WHERE mint = %s
      AND collection_run_id = %s
      AND seconds_after_launch <= %s
    """, (mint, COLLECTION_RUN_ID, seconds_after_launch))
    row = cursor.fetchone()

    total_trades = int(row["total_trades"] or 0)
    buy_count = int(row["buy_count"] or 0)
    sell_count = int(row["sell_count"] or 0)
    unique_traders = int(row["unique_traders"] or 0)
    unique_buyers = int(row["unique_buyers"] or 0)
    unique_sellers = int(row["unique_sellers"] or 0)

    total_volume_sol = float(row["total_volume_sol"] or 0)
    buy_volume_sol = float(row["buy_volume_sol"] or 0)
    sell_volume_sol = float(row["sell_volume_sol"] or 0)
    net_volume_sol = buy_volume_sol - sell_volume_sol

    cursor.execute("""
    SELECT market_cap_sol
    FROM pump_token_trades
    WHERE mint = %s
      AND collection_run_id = %s
      AND seconds_after_launch <= %s
      AND market_cap_sol IS NOT NULL
    ORDER BY seconds_after_launch DESC
    LIMIT 1
    """, (mint, COLLECTION_RUN_ID, seconds_after_launch))
    current_row = cursor.fetchone()
    current_market_cap = current_row["market_cap_sol"] if current_row else tracked.get("market_cap_sol")

    market_cap_change_sol = None
    market_cap_change_percent = None
    if start_market_cap is not None and current_market_cap is not None:
        start_mc = float(start_market_cap)
        current_mc = float(current_market_cap)
        market_cap_change_sol = current_mc - start_mc
        if start_mc != 0:
            market_cap_change_percent = (market_cap_change_sol / start_mc) * 100

    buy_sell_ratio = calculate_ratio(buy_count, sell_count)
    buy_volume_sell_volume_ratio = calculate_ratio(buy_volume_sol, sell_volume_sol)

    volume_speed = total_volume_sol / seconds_after_launch if seconds_after_launch > 0 else None
    trade_speed = total_trades / seconds_after_launch if seconds_after_launch > 0 else None
    buy_speed = buy_count / seconds_after_launch if seconds_after_launch > 0 else None
    sell_speed = sell_count / seconds_after_launch if seconds_after_launch > 0 else None

    creator_buy_count = 0
    creator_sell_count = 0
    creator_buy_volume = 0
    creator_sell_volume = 0

    if creator_wallet:
        cursor.execute("""
        SELECT
            SUM(CASE WHEN tx_type = 'buy' THEN 1 ELSE 0 END) AS creator_buy_count,
            SUM(CASE WHEN tx_type = 'sell' THEN 1 ELSE 0 END) AS creator_sell_count,
            COALESCE(SUM(CASE WHEN tx_type = 'buy' THEN sol_amount ELSE 0 END), 0) AS creator_buy_volume,
            COALESCE(SUM(CASE WHEN tx_type = 'sell' THEN sol_amount ELSE 0 END), 0) AS creator_sell_volume
        FROM pump_token_trades
        WHERE mint = %s
          AND collection_run_id = %s
          AND trader_public_key = %s
          AND seconds_after_launch <= %s
        """, (mint, COLLECTION_RUN_ID, creator_wallet, seconds_after_launch))
        creator_row = cursor.fetchone()

        creator_buy_count = int(creator_row["creator_buy_count"] or 0)
        creator_sell_count = int(creator_row["creator_sell_count"] or 0)
        creator_buy_volume = float(creator_row["creator_buy_volume"] or 0)
        creator_sell_volume = float(creator_row["creator_sell_volume"] or 0)

    creator_sold = creator_sell_count > 0

    cursor.execute("""
    SELECT trader_public_key, SUM(sol_amount) AS total_buy_sol
    FROM pump_token_trades
    WHERE mint = %s
      AND collection_run_id = %s
      AND tx_type = 'buy'
      AND seconds_after_launch <= %s
    GROUP BY trader_public_key
    ORDER BY total_buy_sol DESC
    LIMIT 1
    """, (mint, COLLECTION_RUN_ID, seconds_after_launch))
    top_buyer_row = cursor.fetchone()
    top_buyer_sol = float(top_buyer_row["total_buy_sol"] or 0) if top_buyer_row else 0
    top_buyer_share_percent = (top_buyer_sol / buy_volume_sol * 100) if buy_volume_sol > 0 else None

    cursor.execute("""
    SELECT trader_public_key, SUM(sol_amount) AS total_sell_sol
    FROM pump_token_trades
    WHERE mint = %s
      AND collection_run_id = %s
      AND tx_type = 'sell'
      AND seconds_after_launch <= %s
    GROUP BY trader_public_key
    ORDER BY total_sell_sol DESC
    LIMIT 1
    """, (mint, COLLECTION_RUN_ID, seconds_after_launch))
    top_seller_row = cursor.fetchone()
    top_seller_sol = float(top_seller_row["total_sell_sol"] or 0) if top_seller_row else 0
    top_seller_share_percent = (top_seller_sol / sell_volume_sol * 100) if sell_volume_sol > 0 else None

    largest_buy_sol = row["largest_buy_sol"]
    largest_sell_sol = row["largest_sell_sol"]

    has_large_buy = bool(largest_buy_sol is not None and float(largest_buy_sol) >= 1.0)
    has_large_sell = bool(largest_sell_sol is not None and float(largest_sell_sol) >= 1.0)
    is_sell_pressure_high = bool(sell_volume_sol > buy_volume_sol or sell_count > buy_count)
    has_no_sells = sell_count == 0
    is_high_activity = bool(total_trades >= 10 or unique_traders >= 5 or buy_volume_sol >= 1)

    buy_pressure_score = (buy_count * 1.0) + (unique_buyers * 2.0) + (buy_volume_sol * 5.0)
    sell_pressure_score = (sell_count * 1.5) + (unique_sellers * 2.0) + (sell_volume_sol * 6.0)
    mc_component = float(market_cap_change_percent or 0)
    momentum_score = buy_pressure_score + mc_component - sell_pressure_score

    risk_score = 0
    if creator_sold:
        risk_score += 50
    if has_large_sell:
        risk_score += 25
    if is_sell_pressure_high:
        risk_score += 25
    if top_buyer_share_percent is not None and top_buyer_share_percent >= 80:
        risk_score += 20

    cursor.execute("""
    INSERT INTO pump_token_snapshots (
        collection_run_id, tracked_token_id, mint, seconds_after_launch,
        total_trades, buy_count, sell_count,
        unique_traders, unique_buyers, unique_sellers,
        total_volume_sol, buy_volume_sol, sell_volume_sol, net_volume_sol,
        average_buy_sol, average_sell_sol, largest_buy_sol, largest_sell_sol,
        start_market_cap_sol, current_market_cap_sol, highest_market_cap_sol, lowest_market_cap_sol,
        market_cap_change_sol, market_cap_change_percent,
        buy_sell_ratio, buy_volume_sell_volume_ratio,
        volume_speed_sol_per_second, trade_speed_per_second, buy_speed_per_second, sell_speed_per_second,
        first_trade_seconds, first_buy_seconds, first_sell_seconds,
        creator_buy_count, creator_sell_count, creator_buy_volume_sol, creator_sell_volume_sol, creator_sold,
        top_buyer_sol, top_seller_sol, top_buyer_share_percent, top_seller_share_percent,
        has_large_buy, has_large_sell, is_high_activity, is_sell_pressure_high, has_no_sells,
        buy_pressure_score, sell_pressure_score, momentum_score, risk_score
    )
    VALUES (
