    creator_wallet = data.get("traderPublicKey")

    if not mint or not creator_wallet:
        print("Skipped launch: missing mint or creator wallet.")
        return None

    name = clean_text(data.get("name"))
    symbol = clean_text(data.get("symbol"))
    name_lower = lower_text(name)
    symbol_lower = lower_text(symbol)

    launch_date, launch_hour, launch_day_of_week = get_launch_time_parts(received_at)
    duplicate_name_count, duplicate_symbol_count = get_duplicate_counts(name_lower, symbol_lower)
    creator_previous_launches, creator_previous_migrations = get_creator_previous_stats(creator_wallet)

    ensure_creator_exists(creator_wallet, received_at)

