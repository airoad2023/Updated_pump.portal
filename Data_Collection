def update_result_between_5_and_10(mint: str, seconds_after_launch: int, snapshot: Dict[str, Any]):
    mc_usd = float(snapshot.get("current_market_cap_usd") or 0)

    cursor.execute("""
    SELECT *
    FROM pump_5_10_trade_research_results
    WHERE collection_run_id = %s AND mint = %s
    LIMIT 1
    """, (COLLECTION_RUN_ID, mint))
    result = cursor.fetchone()

    if not result:
        return

    entry_mc = float(result["entry_market_cap_usd"] or 0)
    if entry_mc <= 0:
        return

    current_return = ((mc_usd - entry_mc) / entry_mc) * 100

    old_max_mc = float(result["max_market_cap_usd_5_to_10"] or entry_mc)
    old_min_mc = float(result["min_market_cap_usd_5_to_10"] or entry_mc)

    new_max_mc = max(old_max_mc, mc_usd)
    new_min_mc = min(old_min_mc, mc_usd)

    best_return = ((new_max_mc - entry_mc) / entry_mc) * 100
    worst_drawdown = ((new_min_mc - entry_mc) / entry_mc) * 100

    # Keep previous best exit unless this snapshot creates a new max market cap.
    best_exit_seconds = result["best_exit_seconds"]
    best_exit_label = result["best_exit_label"]
    if mc_usd >= old_max_mc:
        best_exit_seconds = seconds_after_launch
        best_exit_label = seconds_to_label(seconds_after_launch)

    hit_plus_15 = bool(result["hit_plus_15"] or current_return >= 15)
    hit_plus_20 = bool(result["hit_plus_20"] or current_return >= 20)
    hit_plus_30 = bool(result["hit_plus_30"] or current_return >= 30)

    first_hit_15 = result["first_hit_15_seconds"]
    first_hit_20 = result["first_hit_20_seconds"]
    first_hit_30 = result["first_hit_30_seconds"]

    if first_hit_15 is None and current_return >= 15:
        first_hit_15 = seconds_after_launch
    if first_hit_20 is None and current_return >= 20:
        first_hit_20 = seconds_after_launch
    if first_hit_30 is None and current_return >= 30:
        first_hit_30 = seconds_after_launch

    hit_stop_15 = bool(result["hit_stop_minus_15"] or current_return <= -15)
    hit_stop_20 = bool(result["hit_stop_minus_20"] or current_return <= -20)
    hit_stop_30 = bool(result["hit_stop_minus_30"] or current_return <= -30)

    first_stop_15 = result["first_stop_15_seconds"]
    first_stop_20 = result["first_stop_20_seconds"]
    first_stop_30 = result["first_stop_30_seconds"]

    if first_stop_15 is None and current_return <= -15:
        first_stop_15 = seconds_after_launch
    if first_stop_20 is None and current_return <= -20:
        first_stop_20 = seconds_after_launch
    if first_stop_30 is None and current_return <= -30:
        first_stop_30 = seconds_after_launch

    dropped_below_5k = bool(result["dropped_below_5k"] or mc_usd < THRESHOLD_5K)
    dropped_below_7500 = bool(result["dropped_below_7500"] or mc_usd < THRESHOLD_7500)
    dropped_below_10k = bool(result["dropped_below_10k"] or mc_usd < THRESHOLD_10K)

    final_10m_market_cap_usd = result["final_10m_market_cap_usd"]
    final_10m_return_percent = result["final_10m_return_percent"]
    final_10m_above_5k = result["final_10m_above_5k"]
    final_10m_above_7500 = result["final_10m_above_7500"]
    final_10m_above_10k = result["final_10m_above_10k"]
    final_status = result["final_status"]

    if seconds_after_launch == TEN_MIN_SECONDS:
        final_10m_market_cap_usd = mc_usd
        final_10m_return_percent = current_return
        final_10m_above_5k = mc_usd >= THRESHOLD_5K
        final_10m_above_7500 = mc_usd >= THRESHOLD_7500
        final_10m_above_10k = mc_usd >= THRESHOLD_10K

        if hit_plus_30:
            final_status = "hit_plus_30_before_10m"
        elif hit_plus_20:
            final_status = "hit_plus_20_before_10m"
        elif hit_plus_15:
            final_status = "hit_plus_15_before_10m"
        elif final_10m_above_5k:
            final_status = "survived_above_5k_at_10m_no_target"
        else:
            final_status = "failed_before_10m"

    cursor.execute("""
    UPDATE pump_5_10_trade_research_results
    SET
        max_market_cap_usd_5_to_10 = %s,
        min_market_cap_usd_5_to_10 = %s,
        best_return_percent_5_to_10 = %s,
        worst_drawdown_percent_5_to_10 = %s,
        best_exit_seconds = %s,
        best_exit_label = %s,

        hit_plus_15 = %s,
        hit_plus_20 = %s,
        hit_plus_30 = %s,
        first_hit_15_seconds = %s,
        first_hit_20_seconds = %s,
        first_hit_30_seconds = %s,

        hit_stop_minus_15 = %s,
        hit_stop_minus_20 = %s,
        hit_stop_minus_30 = %s,
        first_stop_15_seconds = %s,
        first_stop_20_seconds = %s,
        first_stop_30_seconds = %s,

        dropped_below_5k = %s,
        dropped_below_7500 = %s,
        dropped_below_10k = %s,

        final_10m_market_cap_usd = %s,
        final_10m_return_percent = %s,
        final_10m_above_5k = %s,
        final_10m_above_7500 = %s,
        final_10m_above_10k = %s,
        final_status = %s
    WHERE collection_run_id = %s AND mint = %s
    """, (
        new_max_mc, new_min_mc, best_return, worst_drawdown,
        best_exit_seconds, best_exit_label,
        hit_plus_15, hit_plus_20, hit_plus_30,
        first_hit_15, first_hit_20, first_hit_30,
        hit_stop_15, hit_stop_20, hit_stop_30,
        first_stop_15, first_stop_20, first_stop_30,
        dropped_below_5k, dropped_below_7500, dropped_below_10k,
        final_10m_market_cap_usd, final_10m_return_percent,
        final_10m_above_5k, final_10m_above_7500, final_10m_above_10k,
        final_status,
        COLLECTION_RUN_ID, mint
    ))
    mydb.commit()

    print(
        "5-10 update:", mint,
        "|", seconds_to_label(seconds_after_launch),
        "| MC USD:", round(mc_usd, 2),
        "| return:", round(current_return, 2), "%"
    )


def seconds_to_label(seconds: int) -> str:
    minutes = seconds // 60
    remaining = seconds % 60
    return f"{minutes}:{remaining:02d}"


def should_track_launch(info: Dict[str, Any]) -> bool:
    if TRACK_ALL_LAUNCHES_UNTIL_5_MIN:
        return True

    sol_amount = info.get("sol_amount") or 0
    market_cap_sol = info.get("market_cap_sol") or 0

    return (
        sol_amount >= MIN_SOL_AMOUNT_TO_TRACK
        or market_cap_sol >= MIN_LAUNCH_MARKET_CAP_SOL_TO_TRACK
    )


# =====================================================
# ASYNC SCHEDULER
# =====================================================

async def research_snapshot_scheduler(
    websocket,
    mint: str,
    tracked_token_id: int,
    active_mints: Set[str],
    candidate_mints: Set[str],
    tracked_token_id_by_mint: Dict[str, int],
    launch_time_ts_by_mint: Dict[str, float],
    trade_sequence_by_mint: Dict[str, int],
):
    previous = 0
    is_candidate = False

    for window in SNAPSHOT_WINDOWS:
        await asyncio.sleep(max(0, window - previous))

        snapshot = save_snapshot(mint, tracked_token_id, window)
        if not snapshot:
            previous = window
            continue

        if window == FIVE_MIN_SECONDS:
            mc_usd = float(snapshot.get("current_market_cap_usd") or 0)

            if mc_usd >= THRESHOLD_5K:
                is_candidate = True
                candidate_mints.add(mint)
                create_entry_result(mint, tracked_token_id, snapshot)
                update_result_between_5_and_10(mint, window, snapshot)
                print("Continuing 5–10 research candidate:", mint)
            else:
                # Below $5k at 5m: stop tracking this coin.
                await safe_unsubscribe(websocket, mint)
                cleanup_mint(
                    mint, active_mints, candidate_mints,
                    tracked_token_id_by_mint, launch_time_ts_by_mint,
                    trade_sequence_by_mint
                )
                complete_tracked_token(mint)
                print("Stopped below-$5k coin at 5m:", mint)
                return

        elif window > FIVE_MIN_SECONDS and is_candidate:
            update_result_between_5_and_10(mint, window, snapshot)

        previous = window

    await safe_unsubscribe(websocket, mint)
    cleanup_mint(
        mint, active_mints, candidate_mints,
        tracked_token_id_by_mint, launch_time_ts_by_mint,
        trade_sequence_by_mint
    )
    complete_tracked_token(mint)
    print("Completed 5–10 research tracking:", mint)


async def safe_unsubscribe(websocket, mint: str):
    try:
        await websocket.send(json.dumps({"method": "unsubscribeTokenTrade", "keys": [mint]}))
    except Exception as error:
        print("Unsubscribe error:", mint, "|", error)


def cleanup_mint(
    mint: str,
    active_mints: Set[str],
    candidate_mints: Set[str],
    tracked_token_id_by_mint: Dict[str, int],
    launch_time_ts_by_mint: Dict[str, float],
    trade_sequence_by_mint: Dict[str, int],
):
    active_mints.discard(mint)
    candidate_mints.discard(mint)
    tracked_token_id_by_mint.pop(mint, None)
    launch_time_ts_by_mint.pop(mint, None)
    trade_sequence_by_mint.pop(mint, None)


# =====================================================
# MAIN COLLECTOR
# =====================================================

async def run_collector():
    check_required_tables()
    ensure_research_result_table()

    if not PUMPPORTAL_API_KEY or PUMPPORTAL_API_KEY.startswith("PUT_"):
        raise Exception("Add your real PumpPortal API key before running.")

    tracked_token_id_by_mint: Dict[str, int] = {}
    launch_time_ts_by_mint: Dict[str, float] = {}
    trade_sequence_by_mint: Dict[str, int] = {}

    active_mints: Set[str] = set()
    candidate_mints: Set[str] = set()
    pending_tasks: List[asyncio.Task] = []

    total_launches = 0
    total_tracked = 0
    paid_trade_message_count = 0

    loop = asyncio.get_running_loop()
    start_time = loop.time()
    launch_collection_end = start_time + LAUNCH_COLLECTION_SECONDS

    print("Connected to MySQL.")
    print("Database:", MYSQL_CONFIG["database"])
    print("Collection run:", COLLECTION_RUN_ID)
    print("Launch collection seconds:", LAUNCH_COLLECTION_SECONDS)
    print("Thresholds:", THRESHOLD_5K, THRESHOLD_7500, THRESHOLD_10K)
    print("Snapshot windows:", SNAPSHOT_WINDOWS)

    async with websockets.connect(PUMPPORTAL_URL, ping_interval=20, ping_timeout=20) as websocket:
        print("Connected to PumpPortal WebSocket.")

        await websocket.send(json.dumps({"method": "subscribeNewToken"}))
        print("Subscribed to new token events.")

        await websocket.send(json.dumps({"method": "subscribeMigration"}))
        print("Subscribed to migration events.")

        while True:
            current_loop_time = loop.time()
            launch_window_open = current_loop_time < launch_collection_end

            if not launch_window_open and len(active_mints) == 0:
                print("Launch window closed and all active tracking finished.")
                break

            try:
                message = await asyncio.wait_for(websocket.recv(), timeout=5)
                data = json.loads(message)
            except asyncio.TimeoutError:
                continue
            except json.JSONDecodeError:
                print("Received non-JSON message.")
                continue
            except Exception as error:
                print("WebSocket error:", error)
                continue

            if data.get("message"):
                print("Info:", data.get("message"))
                continue

            tx_type = data.get("txType")
            mint = data.get("mint")
            received_at = now_datetime()

            if not mint:
                continue

            if tx_type == "create":
                if not launch_window_open:
                    continue

                total_launches += 1

                raw_event_id = save_raw_event("launch", mint, received_at, data)
                launch_info = save_launch(data, raw_event_id, received_at)
                if not launch_info:
                    continue

                if total_tracked >= MAX_TOTAL_TRACKED_TOKENS:
                    print("Max total tracked reached. Not tracking new token:", mint)
                    continue

                if len(active_mints) >= MAX_ACTIVE_TRACKED_TOKENS:
                    print("Max active tracked reached. Not tracking new token:", mint)
                    continue

                if not should_track_launch(launch_info):
                    continue

                tracked_token_id = insert_tracked_token(launch_info, "5_10_threshold_research")
                if not tracked_token_id:
                    continue

                await websocket.send(json.dumps({"method": "subscribeTokenTrade", "keys": [mint]}))

                tracked_token_id_by_mint[mint] = tracked_token_id
                launch_time_ts_by_mint[mint] = time.time()
                trade_sequence_by_mint[mint] = 0
                active_mints.add(mint)
                total_tracked += 1

                print(
                    "Tracking until 5m:",
                    mint,
                    "| active:", len(active_mints),
                    "| total tracked:", total_tracked
                )

                pending_tasks.append(asyncio.create_task(research_snapshot_scheduler(
                    websocket,
                    mint,
                    tracked_token_id,
                    active_mints,
                    candidate_mints,
                    tracked_token_id_by_mint,
                    launch_time_ts_by_mint,
                    trade_sequence_by_mint,
                )))

            elif tx_type in ["buy", "sell"]:
                if mint in tracked_token_id_by_mint:
                    paid_trade_message_count += 1
                    save_token_trade(
                        data,
                        tracked_token_id_by_mint,
                        launch_time_ts_by_mint,
                        trade_sequence_by_mint
                    )

                    if paid_trade_message_count % 500 == 0:
                        estimated_sol_used = paid_trade_message_count * 0.000001
                        print(
                            "Paid messages:", paid_trade_message_count,
                            "| estimated SOL:", round(estimated_sol_used, 6),
                            "| active:", len(active_mints),
                            "| candidates:", len(candidate_mints)
                        )

            else:
                raw_event_id = save_raw_event("migration", mint, received_at, data)
                save_migration(data, raw_event_id, received_at)

        if pending_tasks:
            print("Waiting for snapshot tasks...")
            await asyncio.gather(*pending_tasks, return_exceptions=True)

    print_run_summary(total_launches, total_tracked, paid_trade_message_count)


def print_run_summary(total_launches: int, total_tracked: int, paid_trade_message_count: int):
    estimated_sol_used = paid_trade_message_count * 0.000001

    print("\n==============================")
    print("RUN FINISHED")
    print("==============================")
    print("Collection run:", COLLECTION_RUN_ID)
    print("Total launches:", total_launches)
    print("Total tracked:", total_tracked)
    print("Paid trade messages:", paid_trade_message_count)
    print("Estimated SOL used:", round(estimated_sol_used, 6))

    cursor.execute("""
    SELECT
        COUNT(*) AS candidates,
        SUM(CASE WHEN passed_5k = TRUE THEN 1 ELSE 0 END) AS passed_5k,
        SUM(CASE WHEN passed_7500 = TRUE THEN 1 ELSE 0 END) AS passed_7500,
        SUM(CASE WHEN passed_10k = TRUE THEN 1 ELSE 0 END) AS passed_10k,
        SUM(CASE WHEN hit_plus_15 = TRUE THEN 1 ELSE 0 END) AS hit_plus_15,
        SUM(CASE WHEN hit_plus_20 = TRUE THEN 1 ELSE 0 END) AS hit_plus_20,
        SUM(CASE WHEN hit_plus_30 = TRUE THEN 1 ELSE 0 END) AS hit_plus_30
    FROM pump_5_10_trade_research_results
    WHERE collection_run_id = %s
    """, (COLLECTION_RUN_ID,))
    summary = cursor.fetchone()

    print("5m candidates:", summary["candidates"] or 0)
    print("Passed $5k:", summary["passed_5k"] or 0)
    print("Passed $7.5k:", summary["passed_7500"] or 0)
    print("Passed $10k:", summary["passed_10k"] or 0)
    print("Hit +15%:", summary["hit_plus_15"] or 0)
    print("Hit +20%:", summary["hit_plus_20"] or 0)
    print("Hit +30%:", summary["hit_plus_30"] or 0)


if __name__ == "__main__":
    try:
        asyncio.run(run_collector())
    finally:
        try:
            cursor.close()
            mydb.close()
        except Exception:
            pass
